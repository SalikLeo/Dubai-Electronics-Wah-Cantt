{
  "name": "dubai-electronics-stock-manager",
  "private": true,
  "version": "1.0.0",
  "description": "Stock Management System for Dubai Electronics",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node build.js --watch",
    "start": "node build.js --watch",
    "build": "node build.js",
    "electron:start": "electron .",
    "build:win": "node build.js && electron-builder --win --x64"
  },
  "dependencies": {
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.16",
    "electron": "^27.1.2",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.21.5",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5"
  },
  "build": {
    "appId": "com.dubaielectronics.stockmanager",
    "productName": "Dubai Electronics Stock Manager",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
